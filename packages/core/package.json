{
  "name": "@office-open/core",
  "version": "0.10.8",
  "description": "Shared OOXML infrastructure — XML components, validators, converters, charts, and SmartArt",
  "keywords": [
    "core",
    "office-open",
    "ooxml",
    "shared",
    "xml"
  ],
  "homepage": "https://www.office-open.com",
  "bugs": {
    "url": "https://github.com/DemoMacro/office-open/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Demo Macro",
    "email": "abc@imst.xyz",
    "url": "https://www.demomacro.com/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DemoMacro/office-open.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./util/values": {
      "types": "./dist/util/values.d.mts",
      "import": "./dist/util/values.mjs"
    },
    "./smartart": {
      "types": "./dist/smartart/index.d.mts",
      "import": "./dist/smartart/index.mjs"
    },
    "./chart": {
      "types": "./dist/chart/index.d.mts",
      "import": "./dist/chart/index.mjs"
    },
    "./drawingml": {
      "types": "./dist/drawingml/index.d.mts",
      "import": "./dist/drawingml/index.mjs"
    },
    "./descriptor": {
      "types": "./dist/descriptor/index.d.mts",
      "import": "./dist/descriptor/index.mjs"
    },
    "./patch": {
      "types": "./dist/patch/index.d.mts",
      "import": "./dist/patch/index.mjs"
    },
    "./theme": {
      "types": "./dist/theme/index.d.mts",
      "import": "./dist/theme/index.mjs"
    }
  },
  "scripts": {
    "dev": "basis build --stub",
    "build": "vp pack",
    "prepack": "pnpm build",
    "test": "vp test run",
    "check": "vp check --fix",
    "bench": "vp test bench"
  },
  "dependencies": {
    "@noble/hashes": "2.2.0",
    "@office-open/xml": "workspace:*",
    "fflate": "0.8.3"
  }
}
