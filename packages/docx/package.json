{
  "name": "@office-open/docx",
  "version": "0.10.4",
  "description": "Generate, parse, and patch .docx documents with a declarative TypeScript API",
  "keywords": [
    "clippy",
    "create",
    "creator",
    "doc",
    "document",
    "docx",
    "generate",
    "office",
    "officegen",
    "word"
  ],
  "homepage": "https://www.office-open.com",
  "bugs": {
    "url": "https://github.com/DemoMacro/office-open/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Demo Macro",
    "email": "abc@imst.xyz",
    "url": "https://www.demomacro.com/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DemoMacro/office-open.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./generate": {
      "types": "./dist/generate.d.mts",
      "import": "./dist/generate.mjs"
    },
    "./parse": {
      "types": "./dist/parse.d.mts",
      "import": "./dist/parse.mjs"
    },
    "./patch": {
      "types": "./dist/patch/index.d.mts",
      "import": "./dist/patch/index.mjs"
    }
  },
  "scripts": {
    "dev": "basis build --stub",
    "build": "vp pack",
    "prepack": "pnpm build",
    "test": "vp test run",
    "check": "vp check --fix",
    "bench": "vp test bench",
    "typedoc": "typedoc src/index.ts --tsconfig tsconfig.typedoc.json",
    "extract": "tsx scripts/extract-document.ts",
    "demos": "tsx scripts/run-all-demos.ts"
  },
  "dependencies": {
    "@office-open/core": "workspace:*",
    "@office-open/xml": "workspace:*"
  }
}
