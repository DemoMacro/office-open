{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "noEmit": true,
    "declaration": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "sourceMap": true,
    "paths": {
      "@office-open/core": ["./packages/core/src/index.ts"],
      "@office-open/core/*": ["./packages/core/src/*/index.ts"],
      "@office-open/xml": ["./packages/xml/src/index.ts"],
      "@office-open/xml/*": ["./packages/xml/src/*/index.ts"],
      "@office-open/docx": ["./packages/docx/src/index.ts"],
      "@office-open/pptx": ["./packages/pptx/src/index.ts"],
      "@office-open/xlsx": ["./packages/xlsx/src/index.ts"]
    }
  }
}
