{
  "name": "@office-open/core",
  "version": "0.6.6",
  "description": "Shared OOXML infrastructure: XmlComponent, value validators, unit converters",
  "keywords": [
    "core",
    "office-open",
    "ooxml",
    "shared",
    "xml"
  ],
  "homepage": "https://www.office-open.com",
  "bugs": {
    "url": "https://github.com/DemoMacro/office-open/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Demo Macro",
    "email": "abc@imst.xyz",
    "url": "https://imst.xyz/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DemoMacro/office-open.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./values": {
      "types": "./dist/values.d.ts",
      "import": "./dist/values.js"
    },
    "./smartart": {
      "types": "./dist/smartart/index.d.ts",
      "import": "./dist/smartart/index.js"
    },
    "./chart": {
      "types": "./dist/chart/index.d.ts",
      "import": "./dist/chart/index.js"
    },
    "./drawingml": {
      "types": "./dist/drawingml/index.d.ts",
      "import": "./dist/drawingml/index.js"
    }
  },
  "scripts": {
    "dev": "basis build --stub",
    "build": "vp pack",
    "prepack": "pnpm build",
    "test": "vp test run",
    "check": "vp check --fix"
  },
  "dependencies": {
    "@office-open/xml": "workspace:*",
    "fflate": "0.8.3",
    "hash.js": "1.1.7",
    "nanoid": "5.1.11"
  }
}
