{
  "name": "@office-open/monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript toolkit for Office documents — generate, parse, and patch .docx, .pptx, .xlsx",
  "keywords": [
    "docx",
    "office",
    "office-open",
    "ooxml",
    "pptx",
    "typescript",
    "xlsx"
  ],
  "homepage": "https://www.office-open.com",
  "bugs": {
    "url": "https://github.com/DemoMacro/office-open/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Demo Macro",
    "email": "abc@imst.xyz",
    "url": "https://www.demomacro.com/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DemoMacro/office-open.git"
  },
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter \"./packages/**\" -r dev",
    "build": "pnpm --filter \"./packages/**\" -r build",
    "check": "vp check --fix",
    "test": "pnpm --filter \"./packages/**\" -r test",
    "bump": "pnpm --filter \"./packages/**\" -r exec basis version",
    "version": "pnpm --filter \"./packages/**\" -r exec basis version",
    "publish": "pnpm --filter \"./packages/**\" -r exec basis publish",
    "postinstall": "pnpm build && vp config && basis git setup",
    "docs:dev": "pnpm --filter @office-open/docs dev",
    "docs:build": "pnpm --filter @office-open/docs build",
    "docs:generate": "pnpm --filter @office-open/docs generate",
    "docs:preview": "pnpm --filter @office-open/docs preview"
  },
  "devDependencies": {
    "@funish/basis": "0.3.0",
    "@rolldown/plugin-node-polyfills": "1.0.3",
    "@types/node": "25.9.3",
    "@vitest/coverage-v8": "4.1.8",
    "docx": "9.7.1",
    "execa": "9.6.1",
    "happy-dom": "20.10.2",
    "hucre": "0.6.1",
    "inquirer": "14.0.2",
    "libxml2-wasm": "0.7.1",
    "pptxgenjs": "4.0.1",
    "ts-morph": "28.0.0",
    "tsx": "4.22.4",
    "typedoc": "0.28.19",
    "vite-plus": "0.1.24"
  },
  "packageManager": "pnpm@10.33.0"
}
