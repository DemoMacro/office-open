{
  "title": "Comprehensive Workbook",
  "creator": "office-open",
  "description": "A feature-rich spreadsheet demonstrating JSON API capabilities",
  "worksheets": [
    {
      "name": "Data",
      "columns": [
        { "min": 1, "max": 1, "width": 15 },
        { "min": 2, "max": 2, "width": 10 },
        { "min": 3, "max": 3, "width": 10 },
        { "min": 4, "max": 4, "width": 12 },
        { "min": 5, "max": 5, "width": 25 }
      ],
      "rows": [
        {
          "cells": [
            {
              "value": "Name",
              "style": {
                "font": { "bold": true },
                "fill": { "type": "solid", "color": "4472C4" },
                "alignment": { "horizontal": "center" }
              }
            },
            {
              "value": "Qty",
              "style": {
                "font": { "bold": true },
                "fill": { "type": "solid", "color": "4472C4" },
                "alignment": { "horizontal": "center" }
              }
            },
            {
              "value": "Price",
              "style": {
                "font": { "bold": true },
                "fill": { "type": "solid", "color": "4472C4" },
                "alignment": { "horizontal": "center" }
              }
            },
            {
              "value": "Total",
              "style": {
                "font": { "bold": true },
                "fill": { "type": "solid", "color": "4472C4" },
                "alignment": { "horizontal": "center" }
              }
            },
            {
              "value": "Note",
              "style": {
                "font": { "bold": true },
                "fill": { "type": "solid", "color": "4472C4" },
                "alignment": { "horizontal": "center" }
              }
            }
          ]
        },
        {
          "cells": [
            { "value": "Apples" },
            { "value": 10 },
            { "value": 2.5 },
            { "formula": { "formula": "B2*C2" }, "value": 25 },
            { "value": "Fresh fruit", "style": { "font": { "italic": true } } }
          ]
        },
        {
          "cells": [
            { "value": "Bananas" },
            { "value": 5 },
            { "value": 1.8 },
            { "formula": { "formula": "B3*C3" }, "value": 9 },
            { "value": "Tropical import", "style": { "font": { "italic": true } } }
          ]
        },
        {
          "cells": [
            { "value": "Oranges" },
            { "value": 8 },
            { "value": 3.2 },
            { "formula": { "formula": "B4*C4" }, "value": 25.6 },
            { "value": "Seasonal" }
          ]
        },
        {
          "cells": [
            { "value": "Total" },
            { "formula": { "formula": "SUM(B2:B4)" }, "value": 23 },
            { "formula": { "formula": "SUM(C2:C4)" }, "value": 7.5 },
            {
              "formula": { "formula": "SUM(D2:D4)" },
              "value": 59.6,
              "style": { "font": { "bold": true } }
            },
            { "value": "" }
          ]
        }
      ],
      "freezePanes": { "row": 1 },
      "autoFilter": "A1:E5",
      "mergeCells": [
        { "from": { "row": 5, "col": 1 }, "to": { "row": 5, "col": 3 } },
        { "from": { "row": 5, "col": 4 }, "to": { "row": 5, "col": 5 } }
      ]
    },
    {
      "name": "Summary",
      "columns": [
        { "min": 1, "max": 1, "width": 20 },
        { "min": 2, "max": 2, "width": 15 },
        { "min": 3, "max": 3, "width": 15 }
      ],
      "rows": [
        {
          "cells": [
            {
              "value": "Metric",
              "style": { "font": { "bold": true }, "fill": { "type": "solid", "color": "4472C4" } }
            },
            {
              "value": "Value",
              "style": { "font": { "bold": true }, "fill": { "type": "solid", "color": "4472C4" } }
            },
            {
              "value": "Status",
              "style": { "font": { "bold": true }, "fill": { "type": "solid", "color": "4472C4" } }
            }
          ]
        },
        {
          "cells": [
            { "value": "Total Items", "style": { "font": { "bold": true } } },
            { "value": 3, "style": { "alignment": { "horizontal": "center" } } },
            { "value": "OK", "style": { "fill": { "type": "solid", "color": "C6EFCE" } } }
          ]
        },
        {
          "cells": [
            { "value": "Revenue", "style": { "font": { "bold": true } } },
            {
              "value": 59.6,
              "style": { "numFmt": "$#,##0.00", "alignment": { "horizontal": "right" } }
            },
            { "value": "OK", "style": { "fill": { "type": "solid", "color": "C6EFCE" } } }
          ]
        },
        {
          "cells": [
            { "value": "Average Price", "style": { "font": { "bold": true } } },
            {
              "value": 2.5,
              "style": { "numFmt": "$#,##0.00", "alignment": { "horizontal": "right" } }
            },
            { "value": "OK", "style": { "fill": { "type": "solid", "color": "C6EFCE" } } }
          ]
        }
      ]
    },
    {
      "name": "Validation",
      "rows": [
        {
          "cells": [
            { "value": "Category", "style": { "font": { "bold": true } } },
            { "value": "Score", "style": { "font": { "bold": true } } }
          ]
        },
        {
          "cells": [{ "value": "Engineering" }, { "value": 95 }]
        },
        {
          "cells": [{ "value": "Design" }, { "value": 88 }]
        },
        {
          "cells": [{ "value": "Marketing" }, { "value": true }]
        },
        {
          "cells": [{ "value": null }]
        }
      ],
      "dataValidations": [
        {
          "sqref": "B2:B5",
          "type": "whole",
          "operator": "between",
          "formula1": "0",
          "formula2": "100",
          "showErrorMessage": true,
          "errorTitle": "Invalid Score",
          "error": "Score must be between 0 and 100"
        }
      ],
      "conditionalFormats": [
        {
          "sqref": "B2:B5",
          "rules": [
            {
              "type": "cellIs",
              "operator": "greaterThanOrEqual",
              "formulas": ["90"],
              "priority": 1
            }
          ]
        }
      ]
    }
  ]
}
