{
    "name": "@office-open/core",
    "version": "0.1.0",
    "description": "Shared OOXML infrastructure: XmlComponent, value validators, unit converters",
    "keywords": [
        "core",
        "office-open",
        "ooxml",
        "shared",
        "xml"
    ],
    "homepage": "https://github.com/DemoMacro/office-open#readme",
    "bugs": {
        "url": "https://github.com/DemoMacro/office-open/issues"
    },
    "license": "MIT",
    "author": {
        "name": "Demo Macro",
        "email": "abc@imst.xyz",
        "url": "https://imst.xyz/"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/DemoMacro/office-open.git"
    },
    "files": [
        "dist"
    ],
    "type": "module",
    "main": "dist/index.mjs",
    "types": "dist/index.d.mts",
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs"
        },
        "./values": {
            "types": "./dist/values.d.mts",
            "import": "./dist/values.mjs"
        }
    },
    "scripts": {
        "dev": "basis build --stub",
        "build": "basis build",
        "prepack": "pnpm build",
        "test": "vp test run --coverage",
        "test:ci": "vp test run --coverage"
    },
    "dependencies": {
        "@office-open/xml": "workspace:*",
        "hash.js": "1.1.7",
        "nanoid": "5.1.9"
    }
}
