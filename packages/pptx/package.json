{
    "name": "@office-open/pptx",
    "version": "0.3.0",
    "private": true,
    "description": "Generate .pptx files with JS/TS",
    "keywords": [
        "office-open",
        "ooxml",
        "powerpoint",
        "pptx",
        "presentation"
    ],
    "homepage": "https://github.com/DemoMacro/office-open#readme",
    "bugs": {
        "url": "https://github.com/DemoMacro/office-open/issues"
    },
    "license": "MIT",
    "author": {
        "name": "Demo Macro",
        "email": "abc@imst.xyz",
        "url": "https://imst.xyz/"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/DemoMacro/office-open.git"
    },
    "files": [
        "dist"
    ],
    "type": "module",
    "main": "dist/index.mjs",
    "types": "dist/index.d.mts",
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs"
        }
    },
    "scripts": {
        "dev": "basis build --stub",
        "build": "basis build",
        "prepack": "pnpm build",
        "test": "vp test run --coverage",
        "check": "vp check --fix",
        "run-ts": "tsx --tsconfig demo/tsconfig.json"
    },
    "dependencies": {
        "@office-open/core": "workspace:*",
        "@office-open/xml": "workspace:*",
        "fflate": "0.8.2",
        "undio": "0.2.0"
    }
}
