{
    "name": "docx-plus",
    "version": "0.0.6",
    "description": "Easily generate .docx files with JS/TS with a nice declarative API. Works for Node and on the Browser.",
    "keywords": [
        "clippy",
        "create",
        "creator",
        "doc",
        "document",
        "docx",
        "docx-plus",
        "generate",
        "office",
        "officegen",
        "word"
    ],
    "homepage": "https://github.com/DemoMacro/docx-plus#readme",
    "bugs": {
        "url": "https://github.com/DemoMacro/docx-plus/issues"
    },
    "license": "MIT",
    "author": {
        "name": "Demo Macro",
        "email": "abc@imst.xyz",
        "url": "https://imst.xyz/"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/DemoMacro/docx-plus.git"
    },
    "files": [
        "dist"
    ],
    "type": "module",
    "main": "dist/index.umd.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "scripts": {
        "build": "vp pack",
        "test": "vp test run --coverage",
        "prepublishOnly": "pnpm run build --omit=dev",
        "check": "vp check --fix",
        "predemo": "pnpm run build",
        "demo": "tsx ./demo/index.ts",
        "typedoc": "typedoc src/index.ts --tsconfig tsconfig.typedoc.json",
        "cspell": "cspell \"{src,demo,docs,scripts}/**/*.{ts,scss,html,md}\" && cspell \"./*.*\"",
        "serve.docs": "cd docs && docsify serve",
        "extract": "tsx scripts/extract-document.ts",
        "run-ts": "tsx"
    },
    "dependencies": {
        "fflate": "0.8.2",
        "hash.js": "1.1.7",
        "nanoid": "5.1.9",
        "undio": "0.2.0",
        "xml": "1.0.1",
        "xml-js": "1.6.11"
    },
    "devDependencies": {
        "@rolldown/plugin-node-polyfills": "1.0.3",
        "@types/node": "25.6.0",
        "@types/xml": "1.0.11",
        "@vitest/coverage-v8": "4.1.4",
        "cspell": "10.0.0",
        "docsify-cli": "4.4.4",
        "execa": "9.6.1",
        "happy-dom": "20.9.0",
        "inquirer": "13.4.1",
        "pre-commit": "1.2.2",
        "tsx": "4.21.0",
        "typedoc": "0.28.19",
        "typescript": "6.0.2",
        "vite-plus": "0.1.18"
    },
    "pre-commit": [
        "check"
    ],
    "engines": {
        "node": ">=10"
    }
}
